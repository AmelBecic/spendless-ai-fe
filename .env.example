# Copy to .env.local (git-ignored) and fill in real values.
#
# Every key here is NEXT_PUBLIC_*, i.e. inlined into the browser bundle at build
# time. That is deliberate and it is also the limit: a value that must stay
# secret cannot live in this file at all.
#
# NEVER put behind NEXT_PUBLIC_ (or anywhere in this repo):
#   - the Supabase service-role key — it bypasses RLS
#   - ANTHROPIC_API_KEY — this client never calls Anthropic; our API does
# Both belong to the backend (`AmelBecic/spendless-ai-be`) and only there.

# Our API. No trailing slash.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Supabase project URL, e.g. https://abcdefghijklm.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/publishable key. Public by design — it is safe in the bundle
# only because every table has RLS enabled. It is not a substitute for auth.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
